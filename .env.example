# API Configuration
# Copy this file to .env.development and .env.production

# Development environment (.env.development)
# VITE_API_URL=http://localhost:8848

# Production environment (.env.production)
# VITE_API_URL=http://cyber-ai-festival-alb-xxx.ap-south-1.elb.amazonaws.com

# API Key for authentication (required for all endpoints except /health)
VITE_API_KEY=your-api-key-here
